{
	"cSpell.ignoreRegExpList": [ //UID strings
		"uid://[a-y0-8]{1,13}", //These ids use 34 bit digits. IDK why, just how they were made.
		// The internal ids used in resource files
		"ExtResource\\([\"'][0-9a-zA-Z_]+[\"']\\)",
		"[\\[ ]id=[\"'][0-9a-zA-Z_]+[\"'][\\] ]",
		//Default names of gdscript resources local to scenes
		"GDScript_[a-y0-8]{1,5}", //These ids use 34 bit digits. IDK why, just how they were made.
		//Cspell dosent know that utf is a word in programing
		"((UTF)|([uU]tf))([-_ ]?(8|(16)))?"
	],
	"cSpell.ignoreRandomStrings": false,
	"cSpell.overrides": [
		{
			"filename": "SConstruct",
			"languageId": "python"
		}
	],
	"cSpell.unknownWords": "report-all",
	"godotTools.editor.revealTerminal": false,
	"godotFormatterAndLinter.lintSeverityLevel": "Warning", // formatting errors are important here
	"godotFormatterAndLinter.lineLength": 100, // regardless of local prefrence, this is offically suggested
